# Discord Bot (required for bot.py, not needed for api.py)
LEARN_BOT_TOKEN=your_discord_bot_token_here
LEARN_AUTHORIZED_USER_ID=your_discord_user_id_here

# API Server (optional — defaults shown)
# LEARN_API_HOST=0.0.0.0
# LEARN_API_PORT=8080
# LEARN_API_SECRET_KEY=your_secret_key_here

# Optional database path overrides (repo-relative or absolute)
# LEARN_DB_PATH=data/knowledge.db
# LEARN_CHAT_DB_PATH=data/chat_history.db

# LLM Provider
# Default is `openai_compat` if unset. Fill the OpenAI-compatible backend values below.
# LEARN_LLM_PROVIDER=openai_compat

# OpenAI-compatible provider settings
# LEARN_LLM_BASE_URL=https://api.x.ai/v1
# LEARN_LLM_API_KEY=your_api_key_here
# LEARN_LLM_MODEL=grok-3
# LEARN_LLM_MAX_TOKENS=4096



# LEARN_LLM_TEMPERATURE=0.7
# LEARN_LLM_MAX_HISTORY_TOKENS=40000
# LEARN_LLM_THINKING=disabled    # optional: "enabled" or "disabled" for models that support it
# LEARN_QUIZ_STALENESS_TIMEOUT=15
# LEARN_REVIEW_REMINDER_MAX=3
# LEARN_MAX_GRAPH_NODES=500

# Backup settings (optional)
# LEARN_BACKUP_DIR=backups
# LEARN_BACKUP_RETENTION_DAYS=7

# Logging (optional)
# LOG_LEVEL=INFO

# Spaced repetition interval exponent (default 0.075).
# Interval formula: interval_days = exp(mastery_score * SR_INTERVAL_EXPONENT)
# At 0.075: score=50 → ~43 days, score=100 → ~1808 days.
# Only affects NEW reviews; existing interval_days values are unchanged.
# LEARN_SR_INTERVAL_EXPONENT=0.075

# Optional: Embedding model
# LEARN_EMBEDDING_MODEL=all-mpnet-base-v2
# LEARN_VECTOR_SEARCH_LIMIT=10
# LEARN_SIM_DEDUP=0.92
# LEARN_SIM_RELATION=0.5

# Reasoning provider (optional — for two-prompt scheduled quiz generation)
# If set, P1 uses this model for structured question generation.
# Falls back to main LLM provider if not configured.
# LEARN_REASONING_LLM_BASE_URL=https://api.x.ai/v1
# LEARN_REASONING_LLM_API_KEY=your_reasoning_api_key
# LEARN_REASONING_LLM_MODEL=grok-4-1-fast-reasoning
# LEARN_REASONING_LLM_THINKING=enabled
